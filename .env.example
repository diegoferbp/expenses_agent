# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# ID del modelo a usar para la extracción. Un modelo Sonnet suele dar
# buen balance costo/calidad para extracción estructurada.
# Verifica el identificador vigente en https://docs.claude.com
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Google ──────────────────────────────────────────────────
# Ruta al credentials.json (OAuth desktop). NO commitear este archivo.
GOOGLE_CREDENTIALS_PATH=./credentials.json
# Ruta donde se guarda el token tras autorizar. NO commitear.
GOOGLE_TOKEN_PATH=./token.json

# ─── Google Sheets ───────────────────────────────────────────
# ID de la hoja (lo que va entre /d/ y /edit en la URL).
SPREADSHEET_ID=
# Nombre de la pestaña destino.
SHEET_NAME=Movimientos

# ─── Filtro de Gmail ─────────────────────────────────────────
# Remitentes permitidos, separados por comas. OJO: es un filtro de
# conveniencia, NO una frontera de seguridad (el From es spoofeable).
ALLOWED_SENDERS=alertas@tubanco.com,notificaciones@tutarjeta.com
# Etiqueta de Gmail que marca un correo como ya procesado (idempotencia).
PROCESSED_LABEL=gastos-procesados

# ─── Validación ──────────────────────────────────────────────
# Monedas aceptadas (ISO 4217), separadas por comas.
ALLOWED_CURRENCIES=COP,USD,EUR
# Cota superior de cordura para el monto.
MAX_AMOUNT=100000000
